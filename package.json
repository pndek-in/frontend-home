{
  "name": "frontend-home",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix build",
    "dev": "PORT=8081 remix dev --manual",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "remix-serve ./build/index.js",
    "startlocal": "dotenv -e .env remix-serve ./build/index.js",
    "typecheck": "tsc",
    "db-create": "dotenv -e .env sequelize db:create",
    "migrate": "dotenv -e .env sequelize db:migrate",
    "seed": "dotenv -e .env sequelize db:seed:all"
  },
  "dependencies": {
    "@ant-design/static-style-extract": "^1.0.2",
    "@maxmind/geoip2-node": "^5.0.0",
    "@remix-run/node": "^2.4.0",
    "@remix-run/react": "^2.4.0",
    "@remix-run/serve": "^2.4.0",
    "antd": "^5.25.3",
    "bcrypt": "^6.0.0",
    "chart.js": "^4.4.1",
    "cheerio": "^1.1.0",
    "cookie": "^1.0.2",
    "dayjs": "^1.11.10",
    "google-auth-library": "^9.5.0",
    "gsap": "^3.12.4",
    "i18next": "^23.7.11",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-fs-backend": "^2.3.1",
    "i18next-http-backend": "^4.0.0",
    "isbot": "^5.1.28",
    "jalutils": "^1.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.7",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.5.0",
    "react-toastify": "^9.1.3",
    "react-top-loading-bar": "^2.3.1",
    "redis": "^4.7.0",
    "remix-i18next": "^5.4.0",
    "remix-utils": "^7.4.0",
    "sequelize": "^6.35.1",
    "string-randomify": "^1.0.1",
    "ua-parser-js": "^1.0.37"
  },
  "overrides": {
    "estree-util-value-to-estree": "^3.3.3",
    "tar": "^7.5.11",
    "esbuild": "^0.25.0",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@iconify-icon/react": "^1.0.8",
    "@remix-run/dev": "^2.17.4",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "@types/ua-parser-js": "^0.7.39",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "sequelize-cli": "^6.6.2",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.1.6"
  }
}
